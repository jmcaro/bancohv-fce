<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Iniciar sesión | Banco HV FCE</title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="bg-unia-blue min-h-screen flex items-center justify-center">

  <div class="bg-white rounded-2xl shadow-xl p-10 w-full max-w-md mx-4">

    <!-- Logo / Encabezado -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-16 h-16 bg-unia-blue rounded-full mb-4">
        <span class="text-unia-orange font-bold text-2xl">UA</span>
      </div>
      <h1 class="text-2xl font-bold text-unia-blue">Banco de Hojas de Vida</h1>
      <p class="text-unia-gray-dark text-sm mt-1">Facultad de Ciencias Económicas</p>
    </div>

    <!-- Error -->
    <% if (error === 'dominio') { %>
    <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 text-sm mb-6">
      Solo se permiten correos institucionales de la Universidad del Atlántico
      (<span class="font-mono">@uniatlantico.edu.co</span>).
    </div>
    <% } %>

    <!-- Botón Google -->
    <a href="/auth/google"
       class="flex items-center justify-center gap-3 w-full border-2 border-unia-blue text-unia-blue font-semibold py-3 rounded-lg hover:bg-unia-blue hover:text-white transition-colors duration-200">
      <svg class="w-5 h-5" viewBox="0 0 24 24">
        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
      </svg>
      Entrar con correo institucional
    </a>

    <p class="text-center text-xs text-unia-gray-dark mt-6">
      Solo para estudiantes y egresados con correo<br/>
      <span class="font-mono text-unia-blue">@uniatlantico.edu.co</span>
    </p>
  </div>

</body>
</html>
