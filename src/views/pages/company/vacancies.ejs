<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mis Vacantes | Banco HV FCE</title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="bg-unia-gray min-h-screen font-sans">
<%- include('../../partials/navbar') %>
<main class="max-w-4xl mx-auto px-4 py-8">

  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-unia-blue">Mis Vacantes</h1>
      <p class="text-sm text-gray-500 mt-1"><%= company.name %></p>
    </div>
    <a href="/company/vacancies/new"
       class="bg-unia-blue text-white font-semibold px-4 py-2 rounded-lg text-sm hover:bg-unia-blue-light transition-colors">
      + Nueva vacante
    </a>
  </div>

  <% if (vacancies.length === 0) { %>
    <div class="text-center py-16 text-gray-400">
      <p class="text-4xl mb-3">💼</p>
      <p class="text-lg font-medium">No tienes vacantes publicadas</p>
      <a href="/company/vacancies/new" class="inline-block mt-4 bg-unia-blue text-white px-6 py-2 rounded-lg text-sm hover:bg-unia-blue-light transition-colors">
        Publicar primera vacante
      </a>
    </div>
  <% } else { %>
    <div class="space-y-4">
      <% vacancies.forEach(v => { %>
      <div class="bg-white rounded-xl shadow p-5">
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1">
            <div class="flex items-center gap-3">
              <h2 class="font-bold text-unia-blue"><%= v.title %></h2>
              <span class="text-xs px-2 py-0.5 rounded-full font-semibold
                <%= v.status === 'OPEN' ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500' %>">
                <%= v.status === 'OPEN' ? 'Abierta' : 'Cerrada' %>
              </span>
            </div>
            <p class="text-xs text-gray-500 mt-1"><%= v.area %> · <%= v.type %><% if (v.location) { %> · <%= v.location %><% } %></p>
            <p class="text-sm font-semibold text-unia-blue mt-2">
              <%= v._count.applications %> postulación<%= v._count.applications !== 1 ? 'es' : '' %>
            </p>
          </div>
          <div class="flex flex-col gap-2 items-end shrink-0">
            <a href="/company/vacancies/<%= v.id %>/applicants"
               class="text-xs bg-unia-orange text-unia-blue font-semibold px-3 py-1 rounded hover:bg-unia-orange-light transition-colors">
              Ver candidatos
            </a>
            <a href="/company/vacancies/<%= v.id %>/edit"
               class="text-xs border border-unia-blue text-unia-blue px-3 py-1 rounded hover:bg-unia-blue hover:text-white transition-colors">
              Editar
            </a>
            <% if (v.status === 'OPEN') { %>
            <form action="/company/vacancies/<%= v.id %>/close" method="POST">
              <button class="text-xs text-red-500 hover:text-red-700">Cerrar vacante</button>
            </form>
            <% } %>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  <% } %>

</main>
<%- include('../../partials/footer') %>
</body>
</html>
