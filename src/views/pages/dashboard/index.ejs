<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard | Banco HV FCE</title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="bg-unia-gray min-h-screen font-sans">
<%- include('../../partials/navbar') %>
<main class="max-w-5xl mx-auto px-4 py-8">

  <div class="mb-8">
    <h1 class="text-2xl font-bold text-unia-blue">Bienvenido, <%= user.name.split(' ')[0] %></h1>
    <p class="text-gray-500 mt-1"><%= user.email %></p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

    <% if (activeRole === 'STUDENT') { %>
      <a href="/cv" class="bg-white rounded-xl shadow p-6 hover:shadow-md transition-shadow border-l-4 border-unia-blue">
        <div class="text-3xl mb-3">📄</div>
        <h2 class="text-lg font-bold text-unia-blue">Mi Hoja de Vida</h2>
        <p class="text-sm text-gray-500 mt-1">Crea o actualiza tu perfil profesional y sube tus soportes.</p>
      </a>
      <a href="/vacancies" class="bg-white rounded-xl shadow p-6 hover:shadow-md transition-shadow border-l-4 border-unia-orange">
        <div class="text-3xl mb-3">💼</div>
        <h2 class="text-lg font-bold text-unia-blue">Vacantes</h2>
        <p class="text-sm text-gray-500 mt-1">Explora las oportunidades laborales disponibles y postúlate.</p>
      </a>
      <a href="/vacancies/me/applied" class="bg-white rounded-xl shadow p-6 hover:shadow-md transition-shadow border-l-4 border-green-500">
        <div class="text-3xl mb-3">📬</div>
        <h2 class="text-lg font-bold text-unia-blue">Mis Postulaciones</h2>
        <p class="text-sm text-gray-500 mt-1">Revisa el estado de tus candidaturas.</p>
      </a>
    <% } %>

    <% if (activeRole === 'LIDER') { %>
      <a href="/company/vacancies" class="bg-white rounded-xl shadow p-6 hover:shadow-md transition-shadow border-l-4 border-unia-blue">
        <div class="text-3xl mb-3">📋</div>
        <h2 class="text-lg font-bold text-unia-blue">Vacantes</h2>
        <p class="text-sm text-gray-500 mt-1">Gestiona las ofertas de empleo y revisa candidatos.</p>
      </a>
      <a href="/company/vacancies/new" class="bg-white rounded-xl shadow p-6 hover:shadow-md transition-shadow border-l-4 border-unia-orange">
        <div class="text-3xl mb-3">➕</div>
        <h2 class="text-lg font-bold text-unia-blue">Nueva Vacante</h2>
        <p class="text-sm text-gray-500 mt-1">Publica una nueva oferta de trabajo.</p>
      </a>
      <a href="/company/setup" class="bg-white rounded-xl shadow p-6 hover:shadow-md transition-shadow border-l-4 border-gray-300">
        <div class="text-3xl mb-3">🏢</div>
        <h2 class="text-lg font-bold text-unia-blue">Gestionar Empresas</h2>
        <p class="text-sm text-gray-500 mt-1">Registra y actualiza información de empresas.</p>
      </a>
    <% } %>

    <% if (activeRole === 'ADMIN') { %>
      <a href="/admin" class="bg-white rounded-xl shadow p-6 hover:shadow-md transition-shadow border-l-4 border-red-500">
        <div class="text-3xl mb-3">⚙️</div>
        <h2 class="text-lg font-bold text-unia-blue">Panel Admin</h2>
        <p class="text-sm text-gray-500 mt-1">Gestiona usuarios, vacantes y el sistema.</p>
      </a>
      <a href="/cv" class="bg-white rounded-xl shadow p-6 hover:shadow-md transition-shadow border-l-4 border-unia-blue">
        <div class="text-3xl mb-3">📄</div>
        <h2 class="text-lg font-bold text-unia-blue">Mi Hoja de Vida</h2>
        <p class="text-sm text-gray-500 mt-1">Crea o actualiza tu perfil profesional.</p>
      </a>
      <a href="/vacancies" class="bg-white rounded-xl shadow p-6 hover:shadow-md transition-shadow border-l-4 border-unia-orange">
        <div class="text-3xl mb-3">💼</div>
        <h2 class="text-lg font-bold text-unia-blue">Vacantes</h2>
        <p class="text-sm text-gray-500 mt-1">Explora y postúlate a oportunidades.</p>
      </a>
      <a href="/vacancies/me/applied" class="bg-white rounded-xl shadow p-6 hover:shadow-md transition-shadow border-l-4 border-green-500">
        <div class="text-3xl mb-3">📬</div>
        <h2 class="text-lg font-bold text-unia-blue">Mis Postulaciones</h2>
        <p class="text-sm text-gray-500 mt-1">Estado de tus candidaturas.</p>
      </a>
      <a href="/company/vacancies" class="bg-white rounded-xl shadow p-6 hover:shadow-md transition-shadow border-l-4 border-purple-500">
        <div class="text-3xl mb-3">🏢</div>
        <h2 class="text-lg font-bold text-unia-blue">Panel Empresa</h2>
        <p class="text-sm text-gray-500 mt-1">Publica y gestiona vacantes.</p>
      </a>
    <% } %>

  </div>
</main>
<%- include('../../partials/footer') %>
</body>
</html>
