<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= vacancy.title %> | Banco HV FCE</title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="bg-unia-gray min-h-screen font-sans">
<%- include('../../partials/navbar') %>
<main class="max-w-3xl mx-auto px-4 py-8">

  <a href="/vacancies" class="text-sm text-unia-blue hover:underline mb-4 inline-block">← Volver a vacantes</a>

  <div class="bg-white rounded-xl shadow p-8">
    <!-- Encabezado -->
    <div class="flex items-start justify-between gap-4 mb-6">
      <div>
        <h1 class="text-2xl font-bold text-unia-blue"><%= vacancy.title %></h1>
        <p class="text-gray-600 mt-1"><%= vacancy.company.name %></p>
        <div class="flex flex-wrap gap-2 mt-3">
          <span class="bg-unia-gray text-unia-blue text-xs font-semibold px-3 py-1 rounded-full"><%= vacancy.type %></span>
          <span class="bg-unia-orange/20 text-unia-blue text-xs px-3 py-1 rounded-full"><%= vacancy.area %></span>
          <% if (vacancy.location) { %>
            <span class="bg-gray-100 text-gray-600 text-xs px-3 py-1 rounded-full">📍 <%= vacancy.location %></span>
          <% } %>
          <% if (vacancy.salary) { %>
            <span class="bg-green-50 text-green-700 text-xs px-3 py-1 rounded-full">💰 <%= vacancy.salary %></span>
          <% } %>
        </div>
      </div>
      <p class="text-xs text-gray-400 shrink-0"><%= new Date(vacancy.createdAt).toLocaleDateString('es-CO') %></p>
    </div>

    <!-- Descripción -->
    <div class="mb-6">
      <h2 class="text-sm font-bold text-gray-700 uppercase tracking-wide mb-2">Descripción</h2>
      <p class="text-sm text-gray-600 whitespace-pre-line"><%= vacancy.description %></p>
    </div>

    <% if (vacancy.requirements) { %>
    <div class="mb-8">
      <h2 class="text-sm font-bold text-gray-700 uppercase tracking-wide mb-2">Requisitos</h2>
      <p class="text-sm text-gray-600 whitespace-pre-line"><%= vacancy.requirements %></p>
    </div>
    <% } %>

    <!-- Postulación -->
    <div class="border-t border-gray-100 pt-6">
      <% if (applied) { %>
        <div class="bg-green-50 border border-green-200 rounded-lg p-4 text-center">
          <p class="text-green-700 font-semibold">✓ Ya te postulaste a esta vacante</p>
          <p class="text-xs text-green-600 mt-1">
            Estado: <span class="font-semibold">
              <% const labels = {PENDING:'En revisión', REVIEWED:'Revisada', ACCEPTED:'Aceptada', REJECTED:'No seleccionado'} %>
              <%= labels[applied.status] %>
            </span>
          </p>
        </div>
      <% } else { %>
        <h2 class="text-sm font-bold text-gray-700 uppercase tracking-wide mb-3">Postularse</h2>
        <form action="/vacancies/apply" method="POST" class="space-y-4">
          <input type="hidden" name="vacancyId" value="<%= vacancy.id %>" />
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Carta de presentación (opcional)</label>
            <textarea name="coverLetter" rows="5" placeholder="Cuéntale a la empresa por qué eres el candidato ideal..."
                      class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-unia-blue resize-none"></textarea>
          </div>
          <button type="submit"
                  class="w-full bg-unia-blue text-white font-bold py-3 rounded-lg hover:bg-unia-blue-light transition-colors">
            Postularme a esta vacante
          </button>
          <p class="text-xs text-gray-400 text-center">Se compartirá tu hoja de vida registrada en el sistema.</p>
        </form>
      <% } %>
    </div>
  </div>

</main>
<%- include('../../partials/footer') %>
</body>
</html>
