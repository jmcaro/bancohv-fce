<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mis Postulaciones | Banco HV FCE</title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="bg-unia-gray min-h-screen font-sans">
<%- include('../../partials/navbar') %>
<main class="max-w-3xl mx-auto px-4 py-8">

  <h1 class="text-2xl font-bold text-unia-blue mb-6">Mis Postulaciones</h1>

  <% if (applications.length === 0) { %>
    <div class="text-center py-16 text-gray-400">
      <p class="text-4xl mb-3">📬</p>
      <p class="text-lg font-medium">Aún no te has postulado a ninguna vacante</p>
      <a href="/vacancies" class="inline-block mt-4 bg-unia-blue text-white px-6 py-2 rounded-lg text-sm hover:bg-unia-blue-light transition-colors">
        Ver vacantes disponibles
      </a>
    </div>
  <% } else { %>
    <div class="space-y-4">
      <% const statusConfig = {
        PENDING:  { label: 'En revisión',      cls: 'bg-yellow-50 text-yellow-700 border-yellow-200' },
        REVIEWED: { label: 'Revisada',          cls: 'bg-blue-50 text-blue-700 border-blue-200' },
        ACCEPTED: { label: 'Aceptada ✓',       cls: 'bg-green-50 text-green-700 border-green-200' },
        REJECTED: { label: 'No seleccionado',   cls: 'bg-red-50 text-red-700 border-red-200' },
      } %>
      <% applications.forEach(app => { %>
        <% const cfg = statusConfig[app.status] %>
        <div class="bg-white rounded-xl shadow p-5">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <a href="/vacancies/<%= app.vacancy.id %>" class="font-bold text-unia-blue hover:underline"><%= app.vacancy.title %></a>
              <p class="text-sm text-gray-600 mt-1"><%= app.vacancy.company.name %></p>
              <p class="text-xs text-gray-400 mt-1">Postulado el <%= new Date(app.appliedAt).toLocaleDateString('es-CO') %></p>
            </div>
            <span class="shrink-0 text-xs font-semibold px-3 py-1 rounded-full border <%= cfg.cls %>">
              <%= cfg.label %>
            </span>
          </div>
          <% if (app.message) { %>
            <div class="mt-3 p-3 bg-unia-gray rounded-lg border-l-4 border-unia-blue">
              <p class="text-xs font-semibold text-unia-blue mb-1">Mensaje de la empresa</p>
              <p class="text-sm text-gray-700"><%= app.message %></p>
            </div>
          <% } %>
        </div>
      <% }) %>
    </div>
  <% } %>

</main>
<%- include('../../partials/footer') %>
</body>
</html>
