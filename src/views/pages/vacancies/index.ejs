<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Vacantes | Banco HV FCE</title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="bg-unia-gray min-h-screen font-sans">
<%- include('../../partials/navbar') %>
<main class="max-w-5xl mx-auto px-4 py-8">

  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-unia-blue">Vacantes disponibles</h1>
    <span class="text-sm text-gray-500"><%= vacancies.length %> resultado<%= vacancies.length !== 1 ? 's' : '' %></span>
  </div>

  <!-- Filtros -->
  <form method="GET" action="/vacancies" class="bg-white rounded-xl shadow p-4 mb-6 flex flex-wrap gap-3">
    <input type="text" name="q" value="<%= filters.q ?? '' %>" placeholder="Buscar vacante..."
           class="flex-1 min-w-48 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-unia-blue" />
    <select name="area" class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-unia-blue">
      <option value="">Todas las áreas</option>
      <% areas.forEach(a => { %>
        <option value="<%= a %>" <%= filters.area === a ? 'selected' : '' %>><%= a %></option>
      <% }) %>
    </select>
    <select name="type" class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-unia-blue">
      <option value="">Todos los tipos</option>
      <% ['Tiempo completo','Medio tiempo','Práctica','Pasantía','Freelance'].forEach(t => { %>
        <option value="<%= t %>" <%= filters.type === t ? 'selected' : '' %>><%= t %></option>
      <% }) %>
    </select>
    <button type="submit" class="bg-unia-blue text-white font-semibold px-4 py-2 rounded-lg text-sm hover:bg-unia-blue-light transition-colors">
      Buscar
    </button>
    <% if (filters.q || filters.area || filters.type) { %>
      <a href="/vacancies" class="text-sm text-gray-500 self-center hover:text-red-500">× Limpiar</a>
    <% } %>
  </form>

  <!-- Lista -->
  <% if (vacancies.length === 0) { %>
    <div class="text-center py-16 text-gray-400">
      <p class="text-4xl mb-3">🔍</p>
      <p class="text-lg font-medium">No hay vacantes disponibles</p>
      <p class="text-sm mt-1">Intenta con otros filtros o vuelve más tarde.</p>
    </div>
  <% } else { %>
    <div class="space-y-4">
      <% vacancies.forEach(v => { %>
      <a href="/vacancies/<%= v.id %>" class="block bg-white rounded-xl shadow hover:shadow-md transition-shadow p-5">
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1">
            <h2 class="font-bold text-unia-blue text-base"><%= v.title %></h2>
            <p class="text-sm text-gray-600 mt-1"><%= v.company.name %><% if (v.location) { %> · <%= v.location %><% } %></p>
            <p class="text-xs text-gray-400 mt-2 line-clamp-2"><%= v.description.substring(0, 150) %>...</p>
          </div>
          <div class="text-right shrink-0">
            <span class="inline-block bg-unia-gray text-unia-blue text-xs font-semibold px-3 py-1 rounded-full"><%= v.type %></span>
            <% if (v.salary) { %><p class="text-xs text-gray-500 mt-2"><%= v.salary %></p><% } %>
            <p class="text-xs text-gray-400 mt-1"><%= new Date(v.createdAt).toLocaleDateString('es-CO') %></p>
          </div>
        </div>
        <div class="mt-3">
          <span class="inline-block bg-unia-orange/20 text-unia-blue text-xs px-2 py-0.5 rounded"><%= v.area %></span>
        </div>
      </a>
      <% }) %>
    </div>
  <% } %>

</main>
<%- include('../../partials/footer') %>
</body>
</html>
