<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Vacantes | Admin</title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="bg-unia-gray min-h-screen font-sans">
<%- include('../../partials/navbar') %>
<main class="max-w-5xl mx-auto px-4 py-8">

  <div class="flex items-center justify-between mb-6">
    <div>
      <a href="/admin" class="text-xs text-unia-blue hover:underline">← Admin</a>
      <h1 class="text-2xl font-bold text-unia-blue mt-1">Todas las Vacantes</h1>
    </div>
    <span class="text-sm text-gray-500"><%= vacancies.length %> vacante<%= vacancies.length !== 1 ? 's' : '' %></span>
  </div>

  <!-- Filtros -->
  <form method="GET" class="bg-white rounded-xl shadow p-4 mb-6 flex flex-wrap gap-3">
    <input type="text" name="q" value="<%= filters.q ?? '' %>" placeholder="Buscar por título..."
           class="flex-1 min-w-48 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-unia-blue" />
    <select name="status" class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-unia-blue">
      <option value="">Todos los estados</option>
      <option value="OPEN"   <%= filters.status === 'OPEN'   ? 'selected' : '' %>>Abiertas</option>
      <option value="CLOSED" <%= filters.status === 'CLOSED' ? 'selected' : '' %>>Cerradas</option>
      <option value="DRAFT"  <%= filters.status === 'DRAFT'  ? 'selected' : '' %>>Borrador</option>
    </select>
    <button type="submit" class="bg-unia-blue text-white font-semibold px-4 py-2 rounded-lg text-sm hover:bg-unia-blue-light transition-colors">
      Filtrar
    </button>
  </form>

  <!-- Tabla -->
  <div class="bg-white rounded-xl shadow overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-unia-blue text-white">
        <tr>
          <th class="text-left px-4 py-3 font-semibold">Vacante</th>
          <th class="text-left px-4 py-3 font-semibold hidden md:table-cell">Empresa</th>
          <th class="text-left px-4 py-3 font-semibold">Estado</th>
          <th class="text-left px-4 py-3 font-semibold hidden sm:table-cell">Postulaciones</th>
          <th class="text-left px-4 py-3 font-semibold">Acciones</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% vacancies.forEach(v => { %>
        <tr class="hover:bg-unia-gray/50 transition-colors">
          <td class="px-4 py-3">
            <p class="font-medium text-gray-800"><%= v.title %></p>
            <p class="text-xs text-gray-400"><%= v.area %> · <%= v.type %></p>
          </td>
          <td class="px-4 py-3 text-gray-600 hidden md:table-cell"><%= v.company.name %></td>
          <td class="px-4 py-3">
            <form action="/admin/vacancies/<%= v.id %>/status" method="POST">
              <select name="status" onchange="this.form.submit()"
                      class="text-xs border border-gray-300 rounded px-2 py-1 focus:outline-none">
                <option value="OPEN"   <%= v.status === 'OPEN'   ? 'selected' : '' %>>Abierta</option>
                <option value="CLOSED" <%= v.status === 'CLOSED' ? 'selected' : '' %>>Cerrada</option>
                <option value="DRAFT"  <%= v.status === 'DRAFT'  ? 'selected' : '' %>>Borrador</option>
              </select>
            </form>
          </td>
          <td class="px-4 py-3 text-gray-600 hidden sm:table-cell"><%= v._count.applications %></td>
          <td class="px-4 py-3">
            <div class="flex items-center gap-3">
              <a href="/vacancies/<%= v.id %>" class="text-xs text-unia-blue hover:underline">Ver</a>
              <form action="/admin/vacancies/<%= v.id %>/delete" method="POST"
                    onsubmit="return confirm('¿Eliminar esta vacante y todas sus postulaciones?')">
                <button class="text-xs text-red-500 hover:text-red-700">Eliminar</button>
              </form>
            </div>
          </td>
        </tr>
        <% }) %>
        <% if (vacancies.length === 0) { %>
        <tr><td colspan="5" class="px-4 py-8 text-center text-gray-400">No se encontraron vacantes.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>

</main>
<%- include('../../partials/footer') %>
</body>
</html>
