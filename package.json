  "description": "Banco de Hojas de Vida - Facultad de Ciencias Económicas, Universidad del Atlántico",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "css": "npx tailwindcss -i src/public/css/input.css -o src/public/css/styles.css",
